# ─── MQ26 BOT v2 — CUENTA REAL IC MARKETS ────────────────────────────────────
# Copiar como .env y completar con los datos reales
# NUNCA compartir este archivo

MODE=live
LOG_LEVEL=INFO

# ── MT5 Cuenta REAL ──────────────────────────────────────────────────────────
MT5_LOGIN=TU_LOGIN_REAL          # Número de cuenta IC Markets real
MT5_PASSWORD=TU_PASSWORD_REAL    # Password de la cuenta real
MT5_SERVER=ICMarketsSC-Live01    # Servidor real (revisar en MT5)
# Servidores IC Markets posibles:
#   ICMarketsSC-Live01
#   ICMarketsSC-Live02
#   ICMarketsSC-Live03
#   ICMarkets-Live (cTrader)

# ── Telegram Alertas ─────────────────────────────────────────────────────────
# Setup: hablar con @BotFather → /newbot → copiar token
# Chat ID: https://api.telegram.org/bot<TOKEN>/getUpdates
TG_TOKEN=TU_BOT_TOKEN            # Ej: 123456789:AAFhSomeRandomToken
TG_CHAT_ID=TU_CHAT_ID            # Ej: -100123456789 o 987654321
TG_ENABLED=true

# ── Risk (dejar estos valores para $2,000 inicial) ────────────────────────────
RISK_RISK_PER_TRADE_PCT=1.0      # 1% por trade = $20 máx riesgo
RISK_DD_KILL_SWITCH_PCT=10.0     # Kill switch al 10% DD ($200 máx pérdida)
RISK_MAX_DAILY_LOSS_PCT=2.0      # Pausa diaria al 2% ($40 máx/día)
